rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anonymous-auth MVP: every WRITE requires a signed-in identity
    // (request.auth != null) to block scripted/bot abuse — clients sign in
    // anonymously on load, so there is no login UI. Reads stay per-collection as
    // documented. Dev sandboxes keep open read+delete for local tooling.

    function signedIn() { return request.auth != null; }

    function validPublicSignup() {
      return request.resource.data.firstName is string
             && request.resource.data.firstName.size() > 0
             && request.resource.data.firstName.size() <= 80
             && request.resource.data.country is string
             && request.resource.data.country.size() <= 64
             && request.resource.data.team is string
             && request.resource.data.team.size() <= 64
             && request.resource.data.lookingType is string
             && request.resource.data.lookingType.size() > 0
             && request.resource.data.lookingType.size() <= 64
             && request.resource.data.position is int;
    }
    function validPrivateSignup() {
      return request.resource.data.fullName is string
             && request.resource.data.fullName.size() > 0
             && request.resource.data.fullName.size() <= 100
             && request.resource.data.lookingGoal is string
             && request.resource.data.lookingGoal.size() <= 280;
    }
    function validConnection() {
      return request.resource.data.participants is list
             && request.resource.data.participants.size() == 2
             && request.resource.data.fans is map;
    }
    function validFeed() {
      return request.resource.data.text is string
             && request.resource.data.text.size() > 0
             && request.resource.data.text.size() <= 400
             && request.resource.data.firstName is string
             && request.resource.data.firstName.size() <= 80;
    }

    // -- Public fan directory --
    match /signups/{id} {
      allow read: if true;
      allow create: if signedIn() && validPublicSignup();
      allow update, delete: if false;
    }
    match /signups_private/{id} {
      allow read: if false;
      allow create: if signedIn() && validPrivateSignup();
      allow update, delete: if false;
    }
    match /signups_dev/{id} {
      allow read, delete: if true;
      allow create: if signedIn() && validPublicSignup();
      allow update: if false;
    }
    match /signups_private_dev/{id} {
      allow read, delete: if true;
      allow create: if signedIn() && validPrivateSignup();
      allow update: if false;
    }

    // -- Pin trades --
    match /connections/{id} {
      allow read: if true;
      allow create: if signedIn() && validConnection();
      allow update, delete: if false;
    }
    match /connections_dev/{id} {
      allow read, delete: if true;
      allow create: if signedIn() && validConnection();
      allow update: if false;
    }

    // -- Fan-insight surveys (organizer-only) --
    match /surveys/{id} {
      allow read: if false;
      allow create: if signedIn() && request.resource.data.responses is map;
      allow update, delete: if false;
    }
    match /surveys_dev/{id} {
      allow read, delete: if true;
      allow create: if signedIn() && request.resource.data.responses is map;
      allow update: if false;
    }

    // -- Community feed (auto-posted fan intros) --
    match /feed/{id} {
      allow read: if true;
      allow create: if signedIn() && validFeed();
      allow update, delete: if false;
    }
    match /feed_dev/{id} {
      allow read, delete: if true;
      allow create: if signedIn() && validFeed();
      allow update: if false;
    }

    match /counters/{id} {
      allow read: if true;
      allow create, update: if signedIn()
                            && request.resource.data.count is int
                            && request.resource.data.count >= 0;
      allow delete: if false;
    }
  }
}
